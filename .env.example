# Prefer local OpenAI-compatible models first, then switch provider/config
# when using commercial APIs or hosted model gateways.
MODEL_PROVIDER=local-openai-compatible
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5-coder:7b
MODEL_API_KEY=local
AGENT_MAX_TURNS=24
AGENT_TRACE=compact
AGENT_SUBAGENT_TRACE=compact

# Backward-compatible local-only variables are still supported for now:
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=qwen2.5-coder:7b
# LOCAL_MODEL_API_KEY=local
